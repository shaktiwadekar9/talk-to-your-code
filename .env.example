TYC_OLLAMA_BASE_URL=http://127.0.0.1:11434
TYC_CHAT_MODEL=qwen2.5-coder:7b
TYC_PLANNER_MODEL=qwen2.5-coder:7b
TYC_EMBEDDING_MODEL=nomic-embed-text
TYC_DB_PATH=~/.talk_to_your_code/talk_to_your_code.sqlite3
TYC_API_URL=http://127.0.0.1:8000

# Graph-based planner summary
TYC_ENABLE_GRAPH_SUMMARY=true
TYC_GRAPH_SUMMARY_DIR=~/.talk_to_your_code/graph_summaries
TYC_JOERN_SERVER=localhost:8080
TYC_GRAPH_SUMMARY_MAX_ITEMS=3000

# Used by code-graph-ai-summarizer
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MAX_TOKENS=5000
LLM_TEMPERATURE=0.1
